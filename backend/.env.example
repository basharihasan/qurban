# ============================================
# SERVER
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# DATABASE — Supabase PostgreSQL
# Get from: https://app.supabase.com
# Project Settings → Database → Connection string (URI)
# Use "Transaction" mode (port 6543) for serverless/Render
# ============================================
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres

# Alternatively, use individual params:
# DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=[YOUR-PASSWORD]

# ============================================
# JWT
# ============================================
JWT_SECRET=change_this_to_a_secure_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string_64_chars
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# FRONTEND (Vercel deployment URL)
# ============================================
FRONTEND_URL=https://your-app.vercel.app

# ============================================
# WhatsApp Notifications (Fonnte API)
# Get token from https://fonnte.com
# ============================================
WA_API_URL=https://api.fonnte.com/send
WA_API_TOKEN=your_fonnte_api_token_here
WA_ENABLED=false

# ============================================
# FILE UPLOADS
# Note: Render free tier has ephemeral filesystem.
# Uploaded files are lost on redeploy.
# Consider Cloudinary for persistent storage.
# ============================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
